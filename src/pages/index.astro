---
// src/pages/index.astro
import Layout from '../Layouts/Layout.astro'
import ServiceCard from '../components/Vue/ServiceCard.vue'
import ContactForm from '../components/Vue/ContactForm.vue'
import Specialties from '../components/Astro/Specialties.astro'
import WorkGalery from '../components/Astro/WorkGalery.astro'
import ScrollGear from '../components/Vue/ScrollGear.vue'
import Footer from '../components/Astro/Footer.astro'
---

<Layout title="Zorrilla Diésel - Especialistas en Bombas Inyectoras">
  <!-- Header / Navbar -->
  <header class="fixed w-full top-0 z-50 bg-white shadow-md">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16 relative">
        <div class="flex items-center space-x-2">
          <ScrollGear
            class="w-4 h-4 nav:w-7 nav:h-7 lg:w-16 lg:h-16"
            client:load
          />
          <img
            src="/zorrilla-diesel-logo.png"
            alt="Logo Zorrilla Diésel"
            class="h-10 w-auto object-contain"
          />
          <span class="text-xl font-bold text-gray-800">Zorrilla Diésel</span>
        </div>

        <ul class="hidden nav:flex space-x-8">
          <li>
            <a
              href="#servicios"
              class="text-gray-700 hover:text-[#00884a] transition-colors font-medium"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#especialidades"
              class="text-gray-700 hover:text-[#00884a] transition-colors font-medium"
            >
              Especialidades</a
            >
          </li>
          <li>
            <a
              href="#galeria"
              class="text-gray-700 hover:text-[#00884a] transition-colors font-medium"
              >Galería</a
            >
          </li>
          <li>
            <a
              href="#contacto"
              class="text-gray-700 hover:text-[#00884a] transition-colors font-medium"
              >Contacto</a
            >
          </li>
        </ul>

        <button class="nav:hidden text-gray-700">
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </nav>
  </header>

  <!-- Hero Section -->
  <section
    class="pt-24 pb-16 bg-gradient-to-br from-[#00884a] to-[#006937] text-white"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
            Expertos en sistemas de inyección diésel.
          </h1>
          <p class="text-lg md:text-xl text-green-50">
            Con más de 30 años de especialización técnica, nuestro equipo ofrece
            soluciones expertas para las marcas de inyección diésel de mayor
            circulación, garantizando experiencia y fiabilidad en cada servicio.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto"
              class="bg-white text-[#00884a] px-8 py-4 rounded-lg font-bold text-center hover:bg-green-50 transition-all transform hover:scale-105 shadow-lg"
            >
              Solicitar Diagnóstico
            </a>
            <a
              href="#servicios"
              class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-center hover:bg-white hover:text-[#00884a] transition-all"
            >
              Ver Servicios
            </a>
          </div>
        </div>

        <div class="hidden md:block">
          <div
            class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/20"
          >
            <div class="space-y-4">
              <div class="flex items-center space-x-4">
                <div
                  class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center"
                >
                  <span class="text-2xl">⚙️</span>
                </div>
                <div>
                  <p class="font-bold text-lg">Tecnología Bosch</p>
                  <p class="text-green-100">Equipamiento de primer nivel</p>
                </div>
              </div>
              <div class="flex items-center space-x-4">
                <div
                  class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center"
                >
                  <span class="text-2xl">🔧</span>
                </div>
                <div>
                  <p class="font-bold text-lg">Reparaciones Especializadas</p>
                  <p class="text-green-100">Bombas rotativas y lineales</p>
                </div>
              </div>
              <div class="flex items-center space-x-4">
                <div
                  class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center"
                >
                  <span class="text-2xl">✓</span>
                </div>
                <div>
                  <p class="font-bold text-lg">Garantía Certificada</p>
                  <p class="text-green-100">
                    Respaldo en todos nuestros trabajos
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="servicios" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Nuestros Servicios
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Soluciones completas para sistemas diésel con tecnología de punta
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <ServiceCard
          client:visible
          image="/images/linear_diesel_pump.jpg"
          title="Bombas Inyectoras"
          description="Reparación y calibración de bombas mecánicas y electrónicas"
        />

        <ServiceCard
          client:visible
          image="/images/diesel_injector.jpg"
          title="Inyectores"
          description="Limpieza, prueba y reparación de inyectores diésel"
        />

        <ServiceCard
          client:visible
          image="/images/kit_repair.png"
          title="Mantenimiento Preventivo"
          description="Servicio completo de sistemas de inyección"
        />
      </div>
    </div>
  </section>

  <!-- Specialties Section -->
  <Specialties />

  <!-- Gallery Section -->
  <WorkGalery />

  <!-- Contact Section -->
  <section
    id="contacto"
    class="py-20 bg-gradient-to-br from-[#00884a] to-[#006937] text-white"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Contactános</h2>
        <p class="text-lg text-green-100">
          Estamos listos para ayudarte con tu vehículo o camión Diésel.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div class="space-y-8">
          <div
            class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20"
          >
            <div class="flex items-start space-x-4">
              <div
                class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center flex-shrink-0"
              >
                <span class="text-2xl">📍</span>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-2">Ubicación</h3>
                <p class="text-green-100">
                  calle Augusto Roa Bastos 217, Piquete-cue
                </p>
                <p class="text-green-100">Limpio, Paraguay</p>
              </div>
            </div>
          </div>

          <div
            class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20"
          >
            <div class="flex items-start space-x-4">
              <div
                class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center flex-shrink-0"
              >
                <span class="text-2xl">📞</span>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-2">Teléfonos</h3>
                <p class="text-green-100">0991872699</p>
                <p class="text-green-100">0985388914</p>
              </div>
            </div>
          </div>

          <div
            class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20"
          >
            <div class="flex items-start space-x-4">
              <div
                class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center flex-shrink-0"
              >
                <span class="text-2xl">⏰</span>
              </div>
              <div>
                <h3 class="font-bold text-lg mb-2">Horarios</h3>
                <p class="text-green-100">Lunes a Viernes: 7:00 - 18:00</p>
                <p class="text-green-100">Sábados: 7:00 - 13:00</p>
              </div>
            </div>
          </div>
        </div>

        <ContactForm client:visible />
      </div>
    </div>
  </section>

  <!-- Footer -->
  <Footer />
</Layout>
