---
const socialLinks = [
  { title: 'Facebook', href: 'https://www.facebook.com/raul.zorrilla.5688' },
  {
    title: 'Twitter',
    href: 'https://x.com/zorrillaraul1'
  }
]

const quickLinks = [
  { title: 'Servicios', href: '#servicios' },
  { title: 'Especialidades', href: '#especialidades' },
  { title: 'Galería', href: '#galeria' },
  { title: 'Contacto', href: '#contacto' }
]
---

<footer
  class="bg-slate-900 border-t-4 border-[#00884a] pt-12 pb-8 text-slate-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand Section -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <div
            class="w-10 h-10 bg-[#00884a] rounded-lg flex items-center justify-center"
          >
            <span class="text-white text-xl font-bold">ZD</span>
          </div>
          <span class="text-2xl font-bold text-white">Zorrilla Diésel</span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs">
          Especialistas de amplia experiencia en sistemas de inyección diésel.
          Tecnología Bosch y equipamiento de última generación para garantizar
          el mejor rendimiento de tu motor.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3
          class="text-white font-bold text-lg mb-4 border-b-2 border-[#00884a] inline-block pb-1"
        >
          Enlaces Rápidos
        </h3>
        <ul class="space-y-2">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-[#00884a] hover:pl-2 transition-all duration-300 flex items-center"
                >
                  <span class="mr-2">›</span> {link.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Social & Contact -->
      <div>
        <h3
          class="text-white font-bold text-lg mb-4 border-b-2 border-[#00884a] inline-block pb-1"
        >
          Conéctate
        </h3>
        <div class="flex flex-col space-y-4">
          <p class="text-sm">Seguínos en nuestras redes profesionales:</p>
          <div class="flex space-x-4">
            {
              socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-slate-800 hover:bg-[#00884a] text-white p-2 rounded-lg transition-colors duration-300 shadow-md"
                >
                  {link.title}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="border-t border-slate-800 pt-8 mt-8 text-center text-sm text-slate-500"
    >
      <p>
        © {new Date().getFullYear()} Zorrilla Diésel.
      </p>
      <p class="mt-2">
        Desarrollado con <span class="text-red-500">❤️</span> por
        <a
          href="https://github.com/jzorrilla-dev"
          class="text-[#00884a] hover:underline font-medium"
        >
          jzorrilla-dev
        </a>
      </p>
    </div>
  </div>
</footer>
